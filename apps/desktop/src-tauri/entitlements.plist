<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- WKWebView JS engine needs JIT under the hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Sparkle spawns the user's own `claude` (Node) binary in a PTY; allow
       loading of dynamic libraries that aren't signed by our Team ID. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- On-device voice dictation captures the mic via CoreAudio. Under the
       hardened runtime this entitlement is the actual gate; Info.plist's
       NSMicrophoneUsageDescription only supplies the prompt text. Without
       this key macOS denies capture (often with no TCC prompt). -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
