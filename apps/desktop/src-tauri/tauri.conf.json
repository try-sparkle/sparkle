{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sparkle",
  "version": "0.20.2",
  "identifier": "ai.sparkle.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Sparkle",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:3001 ws://localhost:3001 https://storage.googleapis.com https://*.storage.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sparkle"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/try-sparkle/sparkle/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3NTA1ODk5QTQ4NDM0RTYKUldUbU5JU2ttVmhRRjRwZ3MzZlpRRUhzTHFsWkk3dzhMY253UkxzUWQzTGEwa3VOeTZOMWMwVnMK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "resources": [
      "resources/worktree-guard.mjs",
      "resources/sparkle-hook.mjs",
      "resources/mcp-orchestrator-server.js",
      "resources/mcp-control-server.js"
    ],
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
