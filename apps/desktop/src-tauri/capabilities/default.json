{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core APIs (events for PTY streaming, window) + native folder dialog + open external URLs + scoped HTTP to the Chief API. Multi-window: project-* windows created at runtime.",
  "windows": ["main", "project-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "deep-link:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://sparkle.ai/*" },
        { "url": "https://*.sparkle.ai/*" },
        { "url": "http://localhost:3000/*" },
        { "url": "https://www.google.com/*" }
      ]
    },
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.storytell.ai/*" }]
    }
  ]
}
