{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core APIs (events for PTY streaming, window) + native folder dialog + open external URLs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://sparkle.ai" }, { "url": "https://*.sparkle.ai" }]
    }
  ]
}
