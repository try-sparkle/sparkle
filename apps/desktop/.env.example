# PostHog analytics (desktop). Public ingestion key — safe to ship in the app
# bundle (it can only WRITE events, not read your project). Copy to `.env` (or
# `.env.production` for release builds); Vite exposes VITE_* to the webview.
#
# Get these from the PostHog project settings → "Project API Key" after the
# `Sparkle` project is created. Leave unset to run the app with analytics off.
VITE_PUBLIC_POSTHOG_KEY=
# US cloud: https://us.i.posthog.com  •  EU cloud: https://eu.i.posthog.com
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
